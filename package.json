{
  "name": "yt-cast-audio-bridge-repo",
  "private": true,
  "description": "Monorepo wrapper for yt-cast-audio-bridge",
  "workspaces": [
    "yt-cast-audio-bridge/app"
  ],
  "scripts": {
    "start": "npm run -w yt-cast-audio-bridge/app start",
